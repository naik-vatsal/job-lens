ce,\n    posted_at,\n    created_at\nFROM \"joblens\".\"public\".\"bronze_jobs\"", "relation_name": "\"joblens\".\"public\".\"silver_jobs\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-30T23:26:41.559962Z", "completed_at": "2026-03-30T23:26:41.580473Z"}, {"name": "execute", "started_at": "2026-03-30T23:26:41.590413Z", "completed_at": "2026-03-30T23:26:41.807075Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.27644896507263184, "adapter_response": {"_message": "CREATE VIEW", "code": "CREATE VIEW", "rows_affected": -1}, "message": "CREATE VIEW", "failures": null, "unique_id": "model.joblens.silver_matches", "compiled": true, "compiled_code": "\n\nSELECT\n    id,\n    resume_id,\n    job_id,\n    overall_score,\n    semantic_score,\n    keyword_score,\n    classifier_score,\n    fit_label,\n    confidence,\n    matched_skills,\n    missing_skills,\n    experience_gap,\n    summary,\n    created_at\nFROM \"joblens\".\"public\".\"bronze_matches\"\nWHERE overall_score IS NOT NULL\n  AND overall_score BETWEEN 0 AND 100", "relation_name": "\"joblens\".\"public\".\"silver_matches\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-30T23:26:41.541664Z", "completed_at": "2026-03-30T23:26:41.574129Z"}, {"name": "execute", "started_at": "2026-03-30T23:26:41.582535Z", "completed_at": "2026-03-30T23:26:41.810446Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.29169511795043945, "adapter_response": {"_message": "CREATE VIEW", "code": "CREATE VIEW", "rows_affected": -1}, "message": "CREATE VIEW", "failures": null, "unique_id": "model.joblens.gold_market_skills", "compiled": true, "compiled_code": "\n\nSELECT\n    skill_name,\n    COUNT(*) AS demand_count\nFROM \"joblens\".\"public\".\"bronze_jobs\",\n     jsonb_array_elements_text(required_skills::jsonb) AS skill_name\nGROUP BY skill_name\nORDER BY demand_count DESC", "relation_name": "\"joblens\".\"public\".\"gold_market_skills\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-30T23:26:41.883872Z", "completed_at": "2026-03-30T23:26:41.918802Z"}, {"name": "execute", "started_at": "2026-03-30T23:26:41.922309Z", "completed_at": "2026-03-30T23:26:42.205548Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.3617897033691406, "adapter_response": {"_message": "CREATE VIEW", "code": "CREATE VIEW", "rows_affected": -1}, "message": "CREATE VIEW", "failures": null, "unique_id": "model.joblens.gold_resume_gaps", "compiled": true, "compiled_code": "\n\nSELECT\n    resume_id,\n    skill_name,\n    COUNT(*) AS missing_count\nFROM \"joblens\".\"public\".\"silver_matches\",\n     jsonb_array_elements_text(missing_skills::jsonb) AS skill_name\nGROUP BY resume_id, skill_name", "relation_name": "\"joblens\".\"public\".\"gold_resume_gaps\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-30T23:26:41.893474Z", "completed_at": "2026-03-30T23:26:41.933963Z"}, {"name": "execute", "started_at": "2026-03-30T23:26:41.946830Z", "completed_at": "2026-03-30T23:26:42.215391Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.3754556179046631, "adapter_response": {"_message": "CREATE VIEW", "code": "CREATE VIEW", "rows_affected": -1}, "message": "CREATE VIEW", "failures": null, "unique_id": "model.joblens.gold_score_distribution", "compiled": true, "compiled_code": "\n\nSELECT\n    CASE\n        WHEN overall_score <= 30 THEN '0-30'\n        WHEN overall_score <= 50 THEN '31-50'\n        WHEN overall_score <= 70 THEN '51-70'\n        WHEN overall_score <= 85 THEN '71-85'\n        ELSE '86-100'\n    END AS score_bucket,\n    COUNT(*) AS job_count\nFROM \"joblens\".\"public\".\"silver_matches\"\nGROUP BY score_bucket", "relation_name": "\"joblens\".\"public\".\"gold_score_distribution\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "