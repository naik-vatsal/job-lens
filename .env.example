# ── Database ──────────────────────────────────────────────────────────────────
# Railway PostgreSQL plugin provides DATABASE_URL automatically.
# For asyncpg (FastAPI), change the scheme from postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/joblens

# ── Cache / Celery broker ─────────────────────────────────────────────────────
# Railway Redis plugin provides REDIS_URL automatically.
REDIS_URL=redis://host:6379

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-me

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Frontend (set on the frontend Railway service) ────────────────────────────
# Set to the public URL of your Railway API service.
VITE_API_URL=https://your-api-service.up.railway.app
